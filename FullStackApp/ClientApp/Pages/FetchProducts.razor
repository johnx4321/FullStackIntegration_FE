@page "/fetchproducts"
@inject IProductService ProductService

<h3>Product List</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <p class="text-danger">@errorMessage</p>
}

<ul>
    @if (products != null)
    {
        foreach (var product in products)
        {
            <li>@product.Name - $@product.Price (@product.Category?.Name)</li>
        }
    }
    else if (string.IsNullOrEmpty(errorMessage))
    {
        <li>Loading...</li>
    }
</ul>

<div class="mt-3">
    <button class="btn btn-outline-primary btn-sm" @onclick="RefreshProducts">Refresh</button>
</div>

@code {
    private Product[]? products;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync();
    }

    private async Task LoadProductsAsync(bool forceRefresh = false)
    {
        errorMessage = null;

        try
        {
            products = await ProductService.GetProductsAsync(forceRefresh);

            if (products is null)
            {
                errorMessage = "No product data was returned from the API.";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            errorMessage = $"Error: {ex.Message}";
        }
    }

    private async Task RefreshProducts()
    {
        await LoadProductsAsync(forceRefresh: true);
    }
}
